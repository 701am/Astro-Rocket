---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import HeroGrid from '@/components/effects/HeroGrid.astro';
import HeroBeam from '@/components/effects/HeroBeam.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="701am - Earned Media for B2B & Tech Brands"
  description="Earned media for B2B and tech brands. Landing coverage in the publications and AI engines your buyers trust."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="relative isolate overflow-hidden hero-dark-gradient" showScrollIndicator fullHeight>
    <HeroGrid />
    <HeroBeam />
    <div class="relative z-10">
      <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200 mb-6">Earned media for B2B and tech</Badge>

      <h1 slot="title" class="font-display font-semibold leading-tight tracking-tight max-w-5xl mx-auto">
        <span class="text-[clamp(2rem,4vw,2.815rem)] block text-foreground [-webkit-text-fill-color:currentColor]">When buyers and AI look for the best</span>
        <span class="text-[clamp(2rem,4vw,2.815rem)] block text-foreground [-webkit-text-fill-color:currentColor]">in your category, do they find you?</span>
      </h1>

      <p slot="description" class="max-w-3xl mx-auto text-balance text-lg leading-relaxed mt-6">
        I get B2B and tech brands into the credible publications your customers trust
        and the AI engines now quote. Earned coverage that builds authority, drives
        qualified traffic, and shows up where ads cannot reach.
      </p>

     <Fragment slot="actions">
        <Button size="lg" href="/contact">
          Book a 15-minute fit call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="#sprint">
          See how the sprint works
          <Icon name="arrow-down" size="sm" />
        </Button>
      </Fragment>
    </div>
  </Hero>

  <!-- The Shift -->
  <section class="relative z-10 py-28 md:py-40 bg-background-secondary">
    <div class="absolute inset-0 bg-grid opacity-[0.03] pointer-events-none" />
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-8" data-reveal>
      <Badge variant="brand" pill class="self-start">The shift</Badge>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground max-w-3xl text-balance">
        Search changed. Most brands have not noticed yet.
      </h2>
      <div class="space-y-6 max-w-3xl">
        <p class="text-lg text-foreground-secondary leading-relaxed">
          Your buyers do not scroll ten blue links anymore. They ask ChatGPT, Gemini,
          and Google's AI for a recommendation. The brands those engines name are the
          ones with real, third-party editorial coverage behind them. Not the ones
          running the most ads.
        </p>
        <div class="relative pl-8 border-l-2 border-brand-500/40">
          <p class="text-xl text-foreground font-display italic leading-relaxed">
            "That is the quiet shift almost no marketing team has connected: earned
            media has become the input AI trusts most."
          </p>
        </div>
        <p class="text-lg text-foreground-secondary leading-relaxed">
          The brands investing in it now are building a moat that paid budgets cannot buy back later.
        </p>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="relative z-10 py-28 md:py-40 bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-16">
      <div class="flex flex-col gap-6 max-w-3xl" data-reveal>
        <Badge variant="brand" pill class="self-start">What I do</Badge>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground text-balance">
          Earned media, run like a system.
        </h2>
        <p class="text-lg text-foreground-secondary leading-relaxed max-w-2xl">
          I land your brand, your founders, and your point of view in publications
          your buyers and your market actually read. Every placement is chosen to
          do three things at once.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3" data-reveal-children>
        <div class="group relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-brand-500/30">
          <div class="flex flex-col gap-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="badge-check" size="lg" />
            </div>
            <div>
              <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Build credibility</h3>
              <p class="text-base text-foreground-secondary leading-relaxed">
                Through trusted, third-party voices that your buyers already read and respect.
              </p>
            </div>
          </div>
        </div>
        <div class="group relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-brand-500/30">
          <div class="flex flex-col gap-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="trending-up" size="lg" />
            </div>
            <div>
              <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Drive qualified traffic</h3>
              <p class="text-base text-foreground-secondary leading-relaxed">
                Referral traffic that converts better than paid. Readers arrive with trust already built in.
              </p>
            </div>
          </div>
        </div>
        <div class="group relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-brand-500/30">
          <div class="flex flex-col gap-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="zap" size="lg" />
            </div>
            <div>
              <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Feed AI authority</h3>
              <p class="text-base text-foreground-secondary leading-relaxed">
                The authority signals that AI engines and search use to decide who gets named in answers.
              </p>
            </div>
          </div>
        </div>
      </div>

      <p class="text-sm text-foreground-secondary text-center max-w-xl mx-auto" data-reveal>
        No vanity impressions. No "we sent 200 pitches." Coverage you can point to,
        measure, and compound.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="relative z-10 py-28 md:py-40 bg-background-secondary overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-500/[0.02] to-transparent pointer-events-none" />
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-16">
      <div class="flex flex-col gap-6 text-center items-center" data-reveal>
        <Badge variant="brand" pill>The numbers</Badge>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground max-w-3xl text-balance">
          Why earned media outperforms
        </h2>
        <p class="text-lg text-foreground-secondary max-w-2xl leading-relaxed">
          The data is clear. Earned media drives trust, traffic, and revenue in ways
          paid channels simply cannot match.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-children>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">92%</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            of consumers trust earned media above every other form of advertising.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Nielsen</p>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">4.7x</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            the ROI of paid advertising from earned editorial placements.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Baden Bower</p>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">3x</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            better lead conversion from PR-driven traffic vs. paid traffic.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Avaans Media</p>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">20%</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            higher revenue growth over three years for companies that integrate PR.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Avaans Media</p>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">$1k-2.5k+</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            what a tier-1 editorial backlink costs to acquire. If you can buy it at all.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Industry benchmark</p>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-8 text-center transition-all duration-300 hover:shadow-lg">
          <div class="absolute top-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-brand-500/60 to-transparent rounded-full" />
          <p class="text-5xl md:text-6xl font-semibold text-brand-500 font-display mb-3">79% / 30%</p>
          <p class="text-sm text-foreground-secondary leading-relaxed">
            of execs say PR drives value. Only 30% measure it well. I close that gap.
          </p>
          <p class="text-xs text-foreground-subtle mt-4">Every engagement tracked</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Sprint -->
  <section id="sprint" class="relative z-10 py-28 md:py-40 bg-background">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-16">
      <div class="flex flex-col gap-6 max-w-3xl" data-reveal>
        <Badge variant="brand" pill class="self-start">How it works</Badge>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground text-balance">
          A 30-day earned media sprint.
        </h2>
        <p class="text-lg text-foreground-secondary max-w-2xl leading-relaxed">
          Fixed scope. No retainer trap. You should not have to sign a six-month
          retainer to find out if this works. Start with one sprint. Expand when
          the results make the case for you.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3 relative" data-reveal-children>
        <div class="hidden md:block absolute top-12 left-[calc(16.67%+2rem)] right-[calc(16.67%+2rem)] h-0.5 bg-gradient-to-r from-brand-500/20 via-brand-500/40 to-brand-500/20" />
        <div class="relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:shadow-lg">
          <div class="absolute -top-5 left-10 w-10 h-10 rounded-full bg-brand-500 flex items-center justify-center text-white font-semibold text-lg font-display shadow-lg shadow-brand-500/25">1</div>
          <div class="mt-4">
            <Badge variant="brand" pill class="mb-4">Days 1-5</Badge>
            <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Position</h3>
            <p class="text-sm text-foreground-secondary leading-relaxed">
              We sharpen your story, angles, and the specific outlets and journalists
              worth pursuing. Built around what your buyers and the AI engines reward.
            </p>
          </div>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:shadow-lg">
          <div class="absolute -top-5 left-10 w-10 h-10 rounded-full bg-brand-500 flex items-center justify-center text-white font-semibold text-lg font-display shadow-lg shadow-brand-500/25">2</div>
          <div class="mt-4">
            <Badge variant="brand" pill class="mb-4">Days 6-25</Badge>
            <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Pitch</h3>
            <p class="text-sm text-foreground-secondary leading-relaxed">
              Targeted, personalized outreach to the right journalists with newsworthy
              angles. No mass blasts. Pitches that actually get opened and answered.
            </p>
          </div>
        </div>
        <div class="relative bg-card border border-card-border rounded-2xl p-10 transition-all duration-300 hover:shadow-lg">
          <div class="absolute -top-5 left-10 w-10 h-10 rounded-full bg-brand-500 flex items-center justify-center text-white font-semibold text-lg font-display shadow-lg shadow-brand-500/25">3</div>
          <div class="mt-4">
            <Badge variant="brand" pill class="mb-4">Days 26-30</Badge>
            <h3 class="font-display text-2xl font-semibold text-foreground mb-3">Place and Report</h3>
            <p class="text-sm text-foreground-secondary leading-relaxed">
              Coverage lands. You get a clear report: placements, reach, links, traffic,
              and the authority signals built. You will know exactly what your money bought.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="relative z-10 py-28 md:py-40 bg-background-secondary">
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-8" data-reveal>
      <Badge variant="brand" pill class="self-start">Who it is for</Badge>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground max-w-3xl text-balance">
        Built for brands where trust is the whole game.
      </h2>
      <div class="text-lg text-foreground-secondary leading-relaxed max-w-3xl space-y-6">
        <p>
          This works best for <strong class="text-foreground font-medium">B2B tech and SaaS, healthcare and health tech,
          fintech and financial services, education and edtech</strong>, and founder-led
          companies that need authority more than they need another ad campaign.
        </p>
        <div class="relative pl-8 border-l-2 border-brand-500/40">
          <p class="text-xl text-foreground font-display italic leading-relaxed">
            "If your category runs on credibility, earned media is not a nice-to-have.
            It is the channel."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Placements -->
  <section class="relative z-10 py-28 md:py-40 bg-background text-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-500/[0.02] via-transparent to-brand-500/[0.02] pointer-events-none" />
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-8 items-center" data-reveal>
      <Badge variant="brand" pill>Placements</Badge>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground max-w-3xl text-balance">
        Coverage that moves the needle.
      </h2>
      <p class="text-lg text-foreground-secondary max-w-2xl leading-relaxed">
        A decade of getting brands and founders covered. From national outlets to
        the tier-1 trade press your specific buyers rely on.
      </p>
      <Button variant="outline" href="/contact" class="mt-4">
        Let us talk about your story
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="relative z-10 py-28 md:py-40 bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-16 lg:grid-cols-2 items-center">
        <div class="flex flex-col justify-center" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-8">
            <Badge variant="brand" pill class="self-start">About</Badge>
            <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground text-balance">
              Who you are working with.
            </h2>
          </div>
          <p class="text-lg text-foreground-secondary leading-relaxed mb-4">
            I am David Krug. For over a decade I have built earned-media systems
            and digital platforms as a founder and operator. Not a junior account
            exec you will never speak to.
          </p>
          <p class="text-lg text-foreground-secondary leading-relaxed mb-10">
            When you hire me, you get the person who does the work, the strategy,
            and the pitching. That is the difference between an agency line item
            and an actual edge.
          </p>
           <Button variant="outline" href="/about" class="self-start">
            More about me
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <div class="relative" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <div class="absolute -top-6 -left-6 w-24 h-24 rounded-2xl bg-brand-500/10 blur-2xl pointer-events-none" />
          <div class="bg-card border border-card-border rounded-2xl p-10">
            <p class="font-display text-2xl font-semibold text-foreground mb-10 text-center">How I work.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-background-tertiary rounded-xl p-6 flex flex-col items-center justify-center text-center gap-3 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
                <Icon name="target" class="w-10 h-10 text-brand-500" />
                <p class="text-sm font-semibold text-foreground">Targeted outreach</p>
              </div>
              <div class="bg-background-tertiary rounded-xl p-6 flex flex-col items-center justify-center text-center gap-3 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
                <Icon name="bar-chart" class="w-10 h-10 text-brand-500" />
                <p class="text-sm font-semibold text-foreground">Measurable results</p>
              </div>
              <div class="bg-background-tertiary rounded-xl p-6 flex flex-col items-center justify-center text-center gap-3 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
                <Icon name="globe" class="w-10 h-10 text-brand-500" />
                <p class="text-sm font-semibold text-foreground">Global reach</p>
              </div>
              <div class="bg-background-tertiary rounded-xl p-6 flex flex-col items-center justify-center text-center gap-3 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
                <Icon name="zap" class="w-10 h-10 text-brand-500" />
                <p class="text-sm font-semibold text-foreground">AI-ready authority</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative z-10 py-28 md:py-40 bg-background">
    <div class="mx-auto max-w-3xl px-6 flex flex-col gap-10">
      <div class="flex flex-col gap-6 text-center items-center" data-reveal>
        <Badge variant="brand" pill>FAQ</Badge>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground text-balance">
          Common questions
        </h2>
      </div>
      <div data-reveal>
        <Card variant="elevated" padding="lg">
          <Accordion
            items={[
              {
                title: 'How is this different from a PR agency?',
                content: 'You work directly with me, not a rotating junior team. Fixed scope, transparent reporting, and a focus on the outcomes that matter now. Including AI-search visibility, which most agencies have not caught up to.'
              },
              {
                title: 'Can you guarantee coverage?',
                content: 'No honest operator guarantees specific placements. Journalists decide. What I guarantee is the targeted work, the right angles, and full transparency on every pitch and result. My track record speaks to outcomes.'
              },
              {
                title: 'What does it cost?',
                content: 'Sprints are fixed-price and scoped to your goals. Book a fit call and I will quote you directly. No drawn-out proposal process.'
              },
              {
                title: 'How fast can we start?',
                content: 'This week, if there is a fit. I take on a limited number of sprints at a time.'
              },
            ]}
          />
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-28 md:py-40 bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-10">
      <div class="flex flex-col items-center gap-6 text-center" data-reveal>
        <Badge variant="brand" pill>From the blog</Badge>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground text-balance">
          Latest
        </h2>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

      <div class="flex justify-center">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative z-10 py-28 md:py-40 bg-background overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-500/[0.03] via-transparent to-brand-500/[0.03] pointer-events-none" />
    <div class="glitch:hidden mx-auto max-w-3xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold leading-[1.08] tracking-tight text-foreground mb-6 text-balance">
        Your competitors are about to get quoted by the AI your buyers use.
      </h2>
      <p class="text-lg text-foreground-secondary mb-10 text-balance leading-relaxed">
