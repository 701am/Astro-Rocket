---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="701am — Earned Media for B2B & Tech Brands"
  description="Earned media for B2B and tech brands — landing coverage in the publications and AI engines your buyers trust."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator fullHeight>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Earned media for B2B & tech</Badge>

    <h1 slot="title" class="!text-[clamp(1.75rem,9vw,2.75rem)] sm:!text-4xl md:!text-5xl lg:!text-6xl max-w-4xl mx-auto">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">When buyers — and AI — look for the best in your category, do they find you?</span>
    </h1>

    <p slot="description" class="max-w-3xl mx-auto text-balance">
      I get B2B and tech brands into the credible publications your customers trust and the AI engines now quote. Earned coverage that builds authority, drives qualified traffic, and shows up where ads can't reach.
    </p>

   <Fragment slot="actions">
      <Button size="lg" href="/contact">
        Book a 15-minute fit call
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="#sprint">
        See how the sprint works
        <Icon name="arrow-down" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- The Shift -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-6" data-reveal>
      <Badge variant="brand" pill class="self-start">The shift</Badge>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        Search changed. Most brands haven't noticed yet.
      </h2>
      <div class="text-lg text-foreground-muted leading-relaxed space-y-4 max-w-3xl">
        <p>
          Your buyers don't scroll ten blue links anymore. They ask ChatGPT, Gemini, and Google's AI for a recommendation — and the brands those engines name are the ones with real, third-party editorial coverage behind them. Not the ones running the most ads.
        </p>
        <p>
          That's the quiet shift almost no marketing team has connected: <strong class="text-foreground">earned media has become the input AI trusts most</strong>. The brands investing in it now are building a moat that paid budgets can't buy back later.
        </p>
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col gap-4 max-w-3xl" data-reveal>
        <Badge variant="brand" pill class="self-start">What I do</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Earned media, run like a system — not a spray-and-pray.
        </h2>
        <p class="text-lg text-foreground-muted leading-relaxed">
          I land your brand, your founders, and your point of view in publications your buyers and your market actually read. Every placement is chosen to do three things at once:
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <Card hover class="group flex flex-col" data-reveal>
          <div class="flex flex-col gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="badge-check" size="sm" />
            </div>
            <h3 class="font-display text-lg font-bold text-foreground">Build credibility</h3>
            <p class="text-sm text-foreground-muted leading-relaxed flex-1">
              Through trusted, third-party voices that your buyers already read and respect.
            </p>
          </div>
        </Card>
        <Card hover class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex flex-col gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="trending-up" size="sm" />
            </div>
            <h3 class="font-display text-lg font-bold text-foreground">Drive qualified traffic</h3>
            <p class="text-sm text-foreground-muted leading-relaxed flex-1">
              Referral traffic that converts better than paid — because readers arrive with trust already built in.
            </p>
          </div>
        </Card>
        <Card hover class="group flex flex-col" data-reveal data-reveal-delay="2">
          <div class="flex flex-col gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="sm" />
            </div>
            <h3 class="font-display text-lg font-bold text-foreground">Feed AI authority</h3>
            <p class="text-sm text-foreground-muted leading-relaxed flex-1">
              The authority signals that AI engines and search use to decide who gets named in answers.
            </p>
          </div>
        </Card>
      </div>

      <p class="text-sm text-foreground-muted max-w-2xl" data-reveal>
        No vanity impressions. No "we sent 200 pitches." Coverage you can point to, measure, and compound.
      </p>
    </div>
  </section>

  <!-- Why Earned Media Outperforms -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col gap-4 text-center items-center" data-reveal>
        <Badge variant="brand" pill>The numbers</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Why earned media outperforms
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <Card variant="elevated" padding="lg" data-reveal>
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">92%</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            of consumers trust earned media — recommendations and editorial — above every other form of advertising.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Nielsen Global Trust in Advertising</p>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">4.7x</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            the ROI of paid advertising from earned editorial placements.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Baden Bower analysis, 2025–26</p>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">3x</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            better lead conversion from PR-driven organic traffic vs. paid traffic.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Avaans Media, 2025</p>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="3">
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">20%</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            higher revenue growth over three years for companies that integrate PR into their marketing strategy.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Avaans Media, 2025</p>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="4">
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">$1k–2.5k+</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            what a single tier-1 editorial backlink would cost to acquire through link building — if you could buy it at all.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Most top publications don't sell placements</p>
        </Card>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="5">
          <p class="text-4xl font-bold text-brand-500 font-display mb-2">79% / 30%</p>
          <p class="text-sm text-foreground-muted leading-relaxed">
            of executives believe PR drives real business value, but only 30% feel they measure it well. I close that gap.
          </p>
          <p class="text-xs text-foreground-subtle mt-3">Every engagement is tracked and reported</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- The Sprint -->
  <section id="sprint" class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col gap-4" data-reveal>
        <Badge variant="brand" pill class="self-start">How it works</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          A 30-day earned media sprint. Fixed scope. No retainer trap.
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl">
          You shouldn't have to sign a six-month retainer to find out if this works. Start with one sprint. Expand when the results make the case for you.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <Card variant="elevated" padding="lg" class="relative" data-reveal>
          <div class="absolute -top-3 -left-3 w-8 h-8 rounded-full bg-brand-500 flex items-center justify-center text-white font-bold text-sm">1</div>
          <div class="mt-2">
            <Badge variant="brand" pill class="mb-3">Days 1–5</Badge>
            <h3 class="font-display text-lg font-bold text-foreground mb-2">Position</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              We sharpen your story, angles, and the specific outlets and journalists worth pursuing — built around what your buyers and the AI engines reward.
            </p>
          </div>
        </Card>
        <Card variant="elevated" padding="lg" class="relative" data-reveal data-reveal-delay="1">
          <div class="absolute -top-3 -left-3 w-8 h-8 rounded-full bg-brand-500 flex items-center justify-center text-white font-bold text-sm">2</div>
          <div class="mt-2">
            <Badge variant="brand" pill class="mb-3">Days 6–25</Badge>
            <h3 class="font-display text-lg font-bold text-foreground mb-2">Pitch</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              Targeted, personalized outreach to the right journalists with newsworthy angles. No mass blasts — the kind of pitches that actually get opened and answered.
            </p>
          </div>
        </Card>
        <Card variant="elevated" padding="lg" class="relative" data-reveal data-reveal-delay="2">
          <div class="absolute -top-3 -left-3 w-8 h-8 rounded-full bg-brand-500 flex items-center justify-center text-white font-bold text-sm">3</div>
          <div class="mt-2">
            <Badge variant="brand" pill class="mb-3">Days 26–30</Badge>
            <h3 class="font-display text-lg font-bold text-foreground mb-2">Place & Report</h3>
            <p class="text-sm text-foreground-muted leading-relaxed">
              Coverage lands. You get a clear report: placements, reach, links, traffic, and the authority signals built — so you know exactly what your money bought.
            </p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-6" data-reveal>
      <Badge variant="brand" pill class="self-start">Who it's for</Badge>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        Built for brands where trust is the whole game.
      </h2>
      <div class="text-lg text-foreground-muted leading-relaxed">
        <p class="mb-4">
          This works best for <strong class="text-foreground">B2B tech and SaaS, healthcare and health tech, fintech and financial services, education and edtech</strong>, and founder-led companies that need authority more than they need another ad campaign.
        </p>
        <p>
          If your category runs on credibility — and especially if paid channels are restricted or saturated — earned media isn't a nice-to-have. It's the channel.
        </p>
      </div>
    </div>
  </section>

  <!-- Proof / Placements -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-4xl px-6 flex flex-col gap-6 text-center items-center" data-reveal>
      <Badge variant="brand" pill>Placements</Badge>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        Coverage that moves the needle.
      </h2>
      <p class="text-lg text-foreground-muted max-w-2xl leading-relaxed">
        A decade of getting brands and founders covered — from national outlets to the tier-1 trade press your specific buyers live in.
      </p>
      <Button variant="outline" href="/contact">
        Let's talk about your story
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="flex flex-col justify-center" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-6">
            <Badge variant="brand" pill class="self-start">About</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Who you're working with.
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
            I'm David Krug. For over a decade I've built earned-media systems and digital platforms as a founder and operator — not a junior account exec you'll never speak to.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            When you hire me, you get the person who does the work, the strategy, and the pitching. That's the difference between an agency line item and an actual edge.
          </p>
           <Button variant="outline" href="/about" class="self-start">
            More about me
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <p class="text-sm text-foreground mb-5 text-center">How I work.</p>
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="target" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Targeted outreach</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="bar-chart" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Measurable results</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="globe" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Global reach</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="zap" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">AI-ready authority</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-3xl px-6 flex flex-col gap-8">
      <div class="flex flex-col gap-4 text-center items-center" data-reveal>
        <Badge variant="brand" pill>FAQ</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Common questions
        </h2>
      </div>
      <div data-reveal>
        <Accordion
          items={[
            {
              title: 'How is this different from a PR agency?',
              content: 'You work directly with me, not a rotating junior team. Fixed scope, transparent reporting, and a focus on the outcomes that matter now — including AI-search visibility, which most agencies haven\'t caught up to.'
            },
            {
              title: 'Can you guarantee coverage?',
              content: 'No honest operator guarantees specific placements — journalists decide. What I guarantee is the targeted work, the right angles, and full transparency on every pitch and result. My track record speaks to outcomes.'
            },
            {
              title: 'What does it cost?',
              content: 'Sprints are fixed-price and scoped to your goals. Book a fit call and I\'ll quote you directly — no drawn-out proposal process.'
            },
            {
              title: 'How fast can we start?',
              content: 'This week, if there\'s a fit. I take on a limited number of sprints at a time.'
            },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-6 text-center" data-reveal>
        <Badge variant="brand" pill>From the blog</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Latest
        </h2>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

      <div class="flex justify-center">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4 text-balance">
        Your competitors are about to get quoted by the AI your buyers use.
      </h2>
      <p class="text-lg text-foreground-muted mb-6 text-balance">
        Make sure you're in the answer.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Book your 15-minute fit call
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
      <p class="text-sm text-foreground-subtle mt-4">
        No pitch deck, no pressure — just a straight conversation about whether this is a fit.
      </p>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-4 text-balance">
        Your competitors are about to get quoted by the AI your buyers use.
      </h2>
      <p class="text-lg text-foreground-muted mb-6 text-balance">
        Make sure you're in the answer.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Book your 15-minute fit call
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
      <p class="text-sm text-foreground-subtle mt-4">
        No pitch deck, no pressure — just a straight conversation about whether this is a fit.
      </p>
    </LetterGlitchBand>
  </section>
</LandingLayout>
