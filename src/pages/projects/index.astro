---
/**
 * Projects page
 * URL: /projects
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('projects', ({ data }) => !data.draft);
const projects = items.sort((a, b) => a.data.order - b.data.order);
---

<PageLayout
  title="Projects - 701am"
  description="Selected work - websites, tools, and projects."
  eagerReveal
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="layers" size="sm" />
      Selected work
    </Badge>

    <h1 slot="title" class="text-balance">Projects</h1>

    <p slot="description" class="max-w-2xl mx-auto">
      For 20 years I've worked at the intersection of SEO, earned media, and project management — across higher education, edtech, startups, and finance. The throughline is simple: build things worth citing, then run the systems that turn that credibility into durable, compounding growth. Coverage and authority aren't a campaign you finish; they're an engine you operate.
    </p>
  </Hero>

  <!-- All projects -->
  {projects.length > 0 && (
    <section class="relative py-[var(--space-section-md)] bg-background-secondary overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-500/[0.02] via-transparent to-brand-500/[0.02] pointer-events-none" />
      <div class="absolute inset-0 bg-grid opacity-[0.03] pointer-events-none" />
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8 relative">

        <div class="grid gap-6 md:grid-cols-2">
          {projects.map((project) => (
            <Card
              variant="elevated"
              hover
              padding="none"
              href={project.data.placeholder ? undefined : `/projects/${project.id.replace(/\.mdx?$/, '')}`}
              class="group flex flex-col"
              data-reveal
            >
              <div class="flex flex-1 flex-col p-6">
                <div class="mb-3 flex items-start justify-between gap-4">
                  <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                    <Icon name="layers" size="sm" />
                  </div>
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-secondary group-hover:text-brand-500 transition-colors shrink-0 ml-auto" />
                </div>
                <div class="mb-2 flex items-baseline gap-2">
                  <h3 class="font-display text-lg font-bold text-foreground text-balance">{project.data.title}</h3>
                  {project.data.year && (
                    <span class="text-xs text-foreground-secondary">{project.data.year}</span>
                  )}
                </div>
                <p class="text-sm text-foreground-secondary leading-relaxed mb-4 flex-1">{project.data.description}</p>
                {project.data.tags && project.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {project.data.tags.map((tag) => (
                      <Badge variant="brand">{tag}</Badge>
                    ))}
                  </div>
                )}
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

 <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Want something like this?
      </h2>
      <p class="text-lg text-foreground-secondary mb-8 text-balance">
        I build with the same care and craft you see here. If you've got a project, let's see what we can make together.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Start a project
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Want something like this?
      </h2>
      <p class="text-lg text-foreground-secondary mb-8 text-balance">
        I build with the same care and craft you see here. If you've got a project, let's see what we can make together.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Start a project
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>
