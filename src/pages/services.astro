---
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="Services — Earned Media for B2B & Tech Brands — 701am"
  description="Earned media services for B2B and tech brands: media pitching, thought leadership placement, and AI-search authority building."
>
  <Hero layout="centered" size="sm" class="isolate">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="sparkles" size="sm" />
      Services
    </Badge>
    <h1 slot="title">
      <span class="text-foreground">Earned media,</span><br />
      <span class="text-brand-500">run like a system.</span>
    </h1>

    <p slot="description">
      Fixed-scope sprints. No retainer traps. Every engagement is designed to build
      credibility, drive qualified traffic, and feed the AI signals that matter.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="#pitch" variant="outline">
        Media Pitching
        <Icon name="arrow-down" size="sm" class="hero-jump-arrow" />
      </Button>
      <Button size="lg" href="#thought-leadership" variant="outline">
        Thought Leadership
        <Icon name="arrow-down" size="sm" class="hero-jump-arrow" />
      </Button>
      <Button size="lg" href="#ai-authority" variant="outline">
        AI Authority
        <Icon name="arrow-down" size="sm" class="hero-jump-arrow" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Media Pitching -->
  <section id="pitch" class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center gap-4" data-reveal="right" data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start">
            <Icon name="send" size="sm" />
            Media Pitching
          </Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
            Pitches that get opened and answered
          </h2>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            I land your brand, your founders, and your expertise in the publications your buyers actually read. Not mass blasts — targeted, personalized outreach to the right journalists with newsworthy angles.
          </p>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            Every pitch is built around what makes your story relevant right now. No fluff, no jargon, no "we think this would be a great fit" spray-and-pray.
          </p>
          <Button variant="outline" href="/contact" class="self-start mt-2">
            Discuss a pitch sprint
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <div data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="h-full flex flex-col justify-center">
            <div class="flex items-center gap-3 pb-4 mb-4 border-b border-border">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="send" size="md" />
              </div>
              <h3 class="font-display text-base font-semibold text-foreground">What's included</h3>
            </div>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Targeted journalist outreach</span> — every pitch goes to a specific reporter who covers your space, not a thousand-person spray list.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Newsworthy angle development</span> — we find the hook that makes your story timely, relevant, and worth covering.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Placement tracking & reporting</span> — you get a clear report of every placement, link, and the authority signals built.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Follow-up sequences</span> — polite, persistent follow-ups that respect a journalist's inbox and deadline.
                </p>
              </li>
            </ul>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Thought Leadership -->
  <section id="thought-leadership" class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center gap-4 lg:order-2" data-reveal="left" data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start">
            <Icon name="edit" size="sm" />
            Thought Leadership
          </Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
            Get your point of view in the room
          </h2>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            The brands that get quoted are the ones with a clear point of view. I help you develop and place bylined articles, op-eds, and expert commentary in the outlets your market trusts.
          </p>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            From ghostwriting to placement strategy, every piece is positioned to build authority with both human readers and the AI engines that now summarize your category.
          </p>
          <Button variant="outline" href="/contact" class="self-start mt-2">
            Build your authority
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <div class="lg:order-1" data-reveal="right" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="h-full flex flex-col justify-center">
            <div class="flex items-center gap-3 pb-4 mb-4 border-b border-border">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="edit" size="md" />
              </div>
              <h3 class="font-display text-base font-semibold text-foreground">What's included</h3>
            </div>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Bylined article placement</span> — op-eds, expert takes, and contributed pieces placed in tier-1 and trade publications.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Ghostwriting & editing</span> — I write or refine every piece so it sounds like you, not a PR agency.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Media training & messaging</span> — sharpen your story, your talking points, and your positioning before the interview.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Speaker & award nominations</span> — identify and submit for conference stages, panel spots, and industry awards that raise your profile.
                </p>
              </li>
            </ul>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- AI Authority -->
  <section id="ai-authority" class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col justify-center gap-4" data-reveal="right" data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start">
            <Icon name="zap" size="sm" />
            AI Authority
          </Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
            Be the brand AI quotes
          </h2>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            ChatGPT, Gemini, and Google's AI now answer your buyers' questions. The brands those engines name are the ones with real, third-party editorial coverage behind them — not the ones running the most ads.
          </p>
          <p class="text-lg text-foreground-secondary leading-relaxed">
            I build the earned-media foundation that AI engines use as their source of truth. Coverage that compounds — every new placement strengthens the authority signals that drive AI citations.
          </p>
          <Button variant="outline" href="/contact" class="self-start mt-2">
            Build AI authority
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <div data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="h-full flex flex-col justify-center">
            <div class="flex items-center gap-3 pb-4 mb-4 border-b border-border">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="zap" size="md" />
              </div>
              <h3 class="font-display text-base font-semibold text-foreground">What's included</h3>
            </div>
            <ul class="flex flex-col gap-3">
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">AI citation analysis</span> — audit what ChatGPT, Gemini, and Perplexity currently say about your category and where your brand stands.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Authority signal mapping</span> — identify the publications and backlink profiles that carry the most weight with AI training data.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Earned coverage targeting</span> — place stories specifically in the outlets that AI engines trust and cite most frequently.
                </p>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0 mt-1" />
                <p class="text-sm text-foreground-secondary leading-relaxed">
                  <span class="font-semibold text-foreground">Quarterly authority reviews</span> — track how your brand's AI presence evolves and adjust strategy as the landscape shifts.
                </p>
              </li>
            </ul>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Sprint Process -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>How it works</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
            The 30-day earned media sprint
          </h2>
        </div>
        <p class="text-lg text-foreground-secondary max-w-2xl mx-auto text-balance">
          Fixed scope. Fixed price. No retainer trap.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <Card hover data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              1
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground text-balance">Position</h3>
              <p class="text-sm text-foreground-secondary leading-relaxed mt-1.5">
                We sharpen your story, angles, and the specific outlets and journalists worth pursuing. Built around what your buyers and the AI engines reward.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              2
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground text-balance">Pitch</h3>
              <p class="text-sm text-foreground-secondary leading-relaxed mt-1.5">
                Targeted, personalized outreach to the right journalists with newsworthy angles. No mass blasts. Pitches that actually get opened and answered.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              3
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground text-balance">Place</h3>
              <p class="text-sm text-foreground-secondary leading-relaxed mt-1.5">
                Coverage lands in target outlets. Every placement is tracked, measured, and reported so you know exactly what your money bought.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="3">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
              4
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground text-balance">Report & Compound</h3>
              <p class="text-sm text-foreground-secondary leading-relaxed mt-1.5">
                A clear report of placements, reach, links, traffic, and authority signals. The data informs the next sprint — and the results compound.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Let's talk</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to get covered?
      </h2>
      <p class="text-lg text-foreground-secondary mb-8 text-balance">
        Book a 15-minute fit call. No pitch deck, no pressure — just a straight conversation about whether this is a fit.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Book your fit call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to get covered?
      </h2>
      <p class="text-lg text-foreground-secondary mb-8 text-balance">
        Book a 15-minute fit call. No pitch deck, no pressure — just a straight conversation about whether this is a fit.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Book your fit call
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          More about me
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</PageLayout>

<style is:global>
  .services-hero .hero-jump-arrow {
    animation: hero-jump-arrow-bounce 1.8s ease-in-out infinite;
  }
  @keyframes hero-jump-arrow-bounce {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(4px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .services-hero .hero-jump-arrow { animation: none; }
  }

  html { scroll-padding-top: 4rem; }
  @media (max-height: 600px) { html { scroll-padding-top: 4rem; } }
  @media (min-width: 1024px) { html { scroll-padding-top: 4rem; } }

  .reveal-instant[data-reveal],
  .reveal-instant [data-reveal],
  .reveal-instant[data-reveal-children] > *,
  .reveal-instant [data-reveal-children] > * {
    opacity: 1;
    transform: none;
    transition: none;
  }
</style>

<script is:inline>
  (function () {
    function initServicesHeroJump() {
      const hero = document.querySelector('.services-hero');
      if (!hero) return;
      const buttons = hero.querySelectorAll('a[href^="#"]');
      if (!buttons.length) return;

      function revealUpToAndIncluding(target) {
        const reveals = document.querySelectorAll('[data-reveal], [data-reveal-children]');
        Array.prototype.forEach.call(reveals, function (el) {
          const targetFollowsEl =
            el.compareDocumentPosition(target) & Node.DOCUMENT_POSITION_FOLLOWING;
          if (el === target || target.contains(el) || targetFollowsEl) {
            el.classList.add('reveal-instant', 'is-visible');
          }
        });
      }

      const targetIds = [];
      Array.prototype.forEach.call(buttons, function (btn) {
        const hash = btn.getAttribute('href');
        const id = hash ? hash.slice(1) : '';
        if (id) targetIds.push(id);
        btn.addEventListener('click', function () {
          const target = id && document.getElementById(id);
          if (target) revealUpToAndIncluding(target);
        });
      });

      const initialId = location.hash ? location.hash.slice(1) : '';
      if (initialId && targetIds.indexOf(initialId) !== -1) {
        const target = document.getElementById(initialId);
        if (target) revealUpToAndIncluding(target);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initServicesHeroJump);
    } else {
      initServicesHeroJump();
    }
  })();
</script>
