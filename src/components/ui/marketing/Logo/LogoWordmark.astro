---
interface Props {
  class?: string;
  height?: number;
}

const { class: className, height = 28 } = Astro.props;
const aspectRatio = 220 / 64;
const width = Math.round(height * aspectRatio);
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 220 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="701am"
>
  <text x="0" y="46"
    font-family="'Inter Variable', 'Inter', system-ui, sans-serif"
    font-weight="700" font-size="46"
    fill="currentColor" letter-spacing="-0.03em">701</text>
  <text x="76" y="40"
    font-family="'Inter Variable', 'Inter', system-ui, sans-serif"
    font-weight="500" font-size="34"
    class="logo-am" letter-spacing="-0.01em">am</text>
</svg>

<style is:global>
  .logo-am { fill: var(--color-brand-500); }
  .dark .logo-am { fill: var(--color-brand-400); }
</style>
