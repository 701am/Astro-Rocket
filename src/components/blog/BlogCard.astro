---
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  tags?: string[];
  featured?: boolean;
  author?: string;
  image?: ImageMetadata;
  svgSlug?: string;
}

const {
  title,
  description,
  href,
  publishedAt,
  tags = [],
  featured,
  author,
} = Astro.props;

const wordsPerMinute = 200;
const estimatedWords = description.split(' ').length * 10;
const readingTime = Math.max(1, Math.ceil(estimatedWords / wordsPerMinute));
---

<article
  class:list={[
    'group rounded-lg border bg-background p-6 shadow-md ring-1 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-lg',
    featured ? 'border-brand-500/40 ring-brand-500/30 hover:border-brand-500' : 'border-border ring-border/60 hover:border-brand-500/60',
  ]}
  data-reveal
>
  <a href={href} class="block">
    <div class="flex items-center gap-2 mb-3">
      <time datetime={publishedAt.toISOString()} class="text-xs text-foreground-muted">
        {formatDate(publishedAt)}
      </time>
      <span class="text-foreground-subtle">·</span>
      <span class="text-xs text-foreground-muted">{readingTime} min read</span>
      {featured && (
        <>
          <span class="text-foreground-subtle">·</span>
          <span class="text-xs font-medium text-brand-500">Featured</span>
        </>
      )}
    </div>

    <h2 class="font-display text-lg font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400 mb-2 leading-snug">
      {title}
    </h2>

    <p class="text-sm text-foreground-muted line-clamp-2 mb-4 leading-relaxed">
      {description}
    </p>

    {author && (
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-500/10 text-xs font-semibold text-brand-600 dark:text-brand-400">
          {author.charAt(0).toUpperCase()}
        </div>
        <span class="text-xs font-medium text-foreground-secondary">{author}</span>
      </div>
    )}

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="inline-flex items-center rounded-full bg-background-secondary px-2 py-0.5 text-[11px] font-medium text-foreground-muted ring-1 ring-inset ring-border transition-colors group-hover:bg-brand-50 group-hover:text-brand-700 group-hover:ring-brand-200 dark:group-hover:bg-brand-900/20 dark:group-hover:text-brand-400 dark:group-hover:ring-brand-800">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
